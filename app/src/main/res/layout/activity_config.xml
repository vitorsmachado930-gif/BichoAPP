<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="24dp" android:background="#FFFFFF">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
<!--  URL  -->
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="URL do servidor" android:textSize="13sp" android:textColor="#64748b" android:layout_marginBottom="4dp"/>
<EditText android:id="@+id/edit_url" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="https://bichoapp.com.br" android:inputType="textUri" android:textSize="16sp" android:textColor="#000000" android:padding="12dp" android:layout_marginBottom="8dp" android:background="@android:drawable/edit_text"/>
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Endereço completo do sistema. Não altere sem instrução." android:textSize="12sp" android:textColor="#94a3b8" android:layout_marginBottom="24dp"/>
<!--  Impressora  -->
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Impressora (endereço Bluetooth, se externa)" android:textSize="13sp" android:textColor="#64748b" android:layout_marginBottom="4dp"/>
<EditText android:id="@+id/edit_printer" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Ex: 5A:3B:7C:13:2A:9A" android:inputType="textVisiblePassword" android:textSize="16sp" android:textColor="#000000" android:padding="12dp" android:layout_marginBottom="8dp" android:background="@android:drawable/edit_text"/>
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Endereço MAC do Bluetooth da impressora (IposPrinter = 5A:3B:7C:13:2A:9A)" android:textSize="12sp" android:textColor="#94a3b8" android:layout_marginBottom="32dp"/>
<!--  Salvar  -->
<Button android:id="@+id/btn_save" android:layout_width="match_parent" android:layout_height="56dp" android:text="SALVAR CONFIGURAÇÕES" android:textSize="16sp" android:backgroundTint="#0f6b45" android:textColor="#FFFFFF"/>
</LinearLayout>
</ScrollView>
